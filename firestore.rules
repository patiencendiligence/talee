rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isVerified() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == "patiencendiligence@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.nickname is string && data.nickname.size() <= 50 &&
             data.roomIds is list && data.roomIds.size() <= 100;
    }

    function isValidRoom(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.ownerId is string && data.ownerId == request.auth.uid &&
             data.members is list && data.members.size() <= 10 &&
             data.maxMembers is number && data.maxMembers >= 1 && data.maxMembers <= 10 &&
             data.dailyTime is string && data.dailyTime.matches('^[0-9]{2}:[0-9]{2}$') &&
             (data.get('lastActiveDate', '') is string);
    }

    function isValidScene(data) {
      return data.roomId is string && exists(/databases/$(database)/documents/rooms/$(data.roomId)) &&
             data.date is string && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
             data.index is number && data.index >= 0 && data.index <= 9 &&
             data.text is string && data.text.size() <= 2000 &&
             (data.get('imageUrl', null) == null || data.imageUrl is string) &&
             data.createdBy is string && data.createdBy == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidUserUsage(data) {
      return data.dailyCount is number && data.dailyCount >= 0 &&
             data.lastReset is string && data.lastReset.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
             data.updatedAt is timestamp;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isVerified() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                       incoming().keys().hasAll(['uid', 'nickname', 'roomIds']) &&
                       incoming().keys().size() == 3;
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['nickname', 'roomIds'])
      );
    }

    match /rooms/{roomId} {
      function isMember() {
        return isVerified() && (request.auth.uid in existing().members);
      }

      allow get: if isVerified() && (isMember() || isAdmin());
      allow list: if isVerified() && (request.auth.uid in resource.data.members || isAdmin());

      allow create: if isVerified() && isValidRoom(incoming()) && isValidId(roomId) &&
                       incoming().keys().hasAll(['id', 'name', 'ownerId', 'members', 'maxMembers', 'dailyTime']) &&
                       incoming().keys().size() >= 6; // lastActiveDate is optional

      allow update: if isVerified() && (
        isAdmin() ||
        (existing().ownerId == request.auth.uid && isValidRoom(incoming()) &&
         incoming().diff(existing()).affectedKeys().hasAny(['name', 'members', 'maxMembers', 'dailyTime', 'lastActiveDate'])) ||
        (isMember() && incoming().diff(existing()).affectedKeys().hasOnly(['lastActiveDate']))
      );

      allow delete: if isVerified() && (existing().ownerId == request.auth.uid || isAdmin());

      match /scenes/{sceneId} {
        allow get: if isVerified() && (isMember() || isAdmin());
        allow list: if isVerified() && (isMember() || isAdmin());

        allow create: if isVerified() && isValidScene(incoming()) && isValidId(sceneId) &&
                         (exists(/databases/$(database)/documents/rooms/$(roomId)) && 
                          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members);

        allow update: if isVerified() && (
          isAdmin() ||
          (incoming().createdBy == existing().createdBy && isValidScene(incoming()) &&
           incoming().diff(existing()).affectedKeys().hasAny(['text', 'imageUrl']))
        );

        allow delete: if isVerified() && (existing().createdBy == request.auth.uid || isAdmin());
      }
    }

    match /user_usage/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && isValidUserUsage(incoming()) &&
                       incoming().dailyCount == 1 &&
                       incoming().updatedAt == request.time;

      allow update: if isOwner(userId) && isValidUserUsage(incoming()) && (
        // Action: Increment or Reset
        (incoming().dailyCount == existing().dailyCount + 1 || incoming().dailyCount == 1) &&
        incoming().updatedAt == request.time &&
        incoming().diff(existing()).affectedKeys().hasAny(['dailyCount', 'lastReset', 'updatedAt'])
      );
    }

    match /image_cache/{hash} {
      allow read: if isVerified();
      allow create: if isVerified() && 
                       incoming().hash == hash &&
                       incoming().keys().hasAll(['hash', 'imageUrl', 'prompt']) &&
                       incoming().keys().size() == 3;
    }

    match /admins/{adminId} {
      allow read: if isVerified() && (isOwner(adminId) || isAdmin());
    }
  }
}
