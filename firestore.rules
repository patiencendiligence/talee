rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "patiencendiligence@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
                      (request.resource.data.roomIds.size() <= 12 || isAdmin());
    }

    // Room Rules
    match /rooms/{roomId} {
      function getRoom() {
        return get(/databases/$(database)/documents/rooms/$(roomId)).data;
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Filtering is handled by query: members array-contains uid
      
      allow create: if isSignedIn() && 
                      request.resource.data.members is list &&
                      request.auth.uid in request.resource.data.members;
                      
      allow update: if isSignedIn() && (
        (request.auth.uid in resource.data.members) ||
        (request.auth.uid in request.resource.data.members && 
         request.resource.data.members.size() <= resource.data.maxMembers) ||
        isAdmin()
      );

      allow delete: if isAdmin() || isOwner(resource.data.ownerId);

      match /scenes/{sceneId} {
        function isRoomMember() {
          return isSignedIn() && (
            (request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members) ||
            (resource != null && resource.data.keys().hasAll(['members']) && request.auth.uid in resource.data.members)
          );
        }

        allow read: if isSignedIn() && (isRoomMember() || isAdmin());
        
        allow create: if isSignedIn() && 
                        (request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members) && 
                        isValidId(sceneId) &&
                        request.resource.data.index >= 0 && 
                        request.resource.data.index < 7 &&
                        request.resource.data.createdBy == request.auth.uid &&
                        request.resource.data.keys().hasAll(['roomId', 'date', 'index', 'text', 'imageUrl', 'createdBy', 'createdAt', 'isGenerating', 'members']);

        // Only allow updating imageUrl and isGenerating (for AI completion)
        // No manual deletion allowed by users after creation (except maybe admin)
        allow update: if isSignedIn() && (
                         isAdmin() ||
                         (isRoomMember() && 
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['imageUrl', 'isGenerating']))
                       );
                         
        allow delete: if isAdmin();
      }
    }

    // Image Cache
    match /image_cache/{hash} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                      request.resource.data.keys().hasAll(['hash', 'imageUrl', 'prompt']) &&
                      request.resource.data.hash == hash;
    }

    // Admin Access
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }
  }
}
