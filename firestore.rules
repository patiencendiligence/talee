rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isVerified() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == "patiencendiligence@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.get('uid', '') is string && data.get('uid', '') == request.auth.uid &&
             data.get('nickname', '') is string && data.get('nickname', '').size() <= 50 &&
             data.get('roomIds', []) is list && data.get('roomIds', []).size() <= 100;
    }

    function isValidRoom(data) {
      return data.get('id', '') is string && data.get('id', '').size() <= 128 &&
             data.get('name', '') is string && data.get('name', '').size() <= 100 &&
             data.get('ownerId', '') is string && 
             data.get('members', []) is list && data.get('members', []).size() <= 10 &&
             data.get('maxMembers', 4) is number && data.get('maxMembers', 4) >= 1 && data.get('maxMembers', 4) <= 10 &&
             data.get('dailyTime', '00:00') is string && data.get('dailyTime', '').matches('^[0-9]{2}:[0-9]{2}$') &&
             (data.get('lastActiveDate', '') is string) &&
             (data.get('dailyStyles', {}) is map);
    }

    function isValidScene(data) {
      return data.get('roomId', '') is string && 
             data.get('date', '') is string && data.get('date', '').matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
             data.get('index', 0) is number && data.get('index', 0) >= 0 && data.get('index', 0) <= 9 &&
             data.get('text', '') is string && data.get('text', '').size() <= 2000 &&
             (data.get('imageUrl', null) == null || data.get('imageUrl', '') is string) &&
             (data.get('imageType', '') is string) &&
             (data.get('isGenerating', false) is bool) &&
             (data.get('needsRetry', false) is bool) &&
             data.get('createdBy', '') is string &&
             data.get('members', []) is list && data.get('members', []).size() <= 10 &&
             (data.get('createdAt', null) != null);
    }

    function isValidUserUsage(data) {
      return data.get('dailyCount', 0) is number && data.get('dailyCount', 0) >= 0 &&
             data.get('lastReset', '') is string && data.get('lastReset', '').matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
             (data.get('updatedAt', null) == null || data.get('updatedAt', null) is timestamp || data.get('updatedAt', null) is string);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isVerified() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                       incoming().keys().hasAll(['uid', 'nickname', 'roomIds']);
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['nickname', 'roomIds'])
      );
    }

    match /rooms/{roomId} {
      function isMember() {
        return isVerified() && (request.auth.uid in existing().get('members', []));
      }

      function isJoinAction() {
        return incoming().get('members', []).hasAll(existing().get('members', [])) && 
               incoming().get('members', []).size() == existing().get('members', []).size() + 1 &&
               (request.auth.uid in incoming().get('members', [])) &&
               !(request.auth.uid in existing().get('members', [])) &&
               incoming().diff(existing()).affectedKeys().hasOnly(['members', 'lastActiveDate']) &&
               existing().get('members', []).size() < (existing().get('maxMembers', 4));
      }

      allow get: if isVerified();
      allow list: if isVerified();

      allow create: if isVerified() && isValidRoom(incoming()) && 
                       incoming().ownerId == request.auth.uid && 
                       isValidId(roomId);

      allow update: if isVerified() && isValidRoom(incoming()) && (
        isAdmin() ||
        isJoinAction() ||
        (existing().ownerId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasAny(['name', 'members', 'maxMembers', 'dailyTime', 'lastActiveDate', 'dailyStyles'])) ||
        (isMember() && incoming().diff(existing()).affectedKeys().hasOnly(['lastActiveDate', 'dailyStyles']))
      );

      allow delete: if isVerified() && (existing().ownerId == request.auth.uid || isAdmin());

      match /scenes/{sceneId} {
        function isSceneMember() {
          return isVerified() && (request.auth.uid in resource.data.get('members', []));
        }

        function isRoomMember() {
          return isVerified() && (request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.get('members', []));
        }

        allow get: if isVerified() && (isSceneMember() || isRoomMember() || isAdmin());
        allow list: if isVerified() && (isSceneMember() || isRoomMember() || isAdmin());

        allow create: if isVerified() && (isAdmin() || (
                         isValidScene(incoming()) && 
                         incoming().get('createdBy', '') == request.auth.uid && 
                         isValidId(sceneId) && 
                         isRoomMember()
                       ));

        allow update: if isVerified() && (
          isAdmin() ||
          (isRoomMember() && isValidScene(incoming()) && 
           incoming().get('createdBy', '') == existing().get('createdBy', '') && // creator is immutable
           incoming().get('members', []) == existing().get('members', []) && // members list should be immutable via scene update
           (
             // Action 1: Creator updating their own text/meta
             (existing().get('createdBy', '') == request.auth.uid && 
              incoming().diff(existing()).affectedKeys().hasAny(['text', 'imageUrl', 'imageType', 'isGenerating', 'needsRetry'])) ||
             // Action 2: Any member triggering AI retry/finish
             (incoming().diff(existing()).affectedKeys().hasOnly(['imageUrl', 'imageType', 'isGenerating', 'needsRetry']))
           )
          )
        );

        allow delete: if isVerified() && (existing().get('createdBy', '') == request.auth.uid || isRoomMember() || isAdmin());
      }
    }

    match /user_usage/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && isValidUserUsage(incoming()) &&
                       incoming().dailyCount == 1;

      allow update: if isOwner(userId) && isValidUserUsage(incoming()) && (
        // Action: Increment or Reset
        (incoming().dailyCount == existing().dailyCount + 1 || incoming().dailyCount == 1) &&
        incoming().diff(existing()).affectedKeys().hasAny(['dailyCount', 'lastReset', 'updatedAt'])
      );
    }

    match /image_cache/{hash} {
      allow read: if isVerified();
      allow create, update: if isVerified() && 
                       (incoming().get('hash', hash) == hash) &&
                       incoming().keys().hasAll(['imageUrl', 'prompt']);
    }

    match /admins/{adminId} {
      allow read: if isVerified() && (isOwner(adminId) || isAdmin());
    }
  }
}
